# Docker Compose publishes the container's fixed port 3000 on loopback.
MCP_HOST_IP=127.0.0.1
MCP_HOST_PORT=3000

# Used when X-QuickBooks-Environment is omitted by the MCP client.
QUICKBOOKS_DEFAULT_ENVIRONMENT=sandbox

# Local OAuth helper configuration. These values are never passed to the HTTP
# MCP container. Register QUICKBOOKS_REDIRECT_URI exactly in the Intuit app.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/callback

# Written by `npm run auth` and rotated by `npm run token`.
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=

# Optional CORS origin for browser-based clients.
MCP_CORS_ORIGIN=*

# Optional: restrict which tool categories are registered.
QUICKBOOKS_DISABLE_WRITE=false
QUICKBOOKS_DISABLE_UPDATE=false
QUICKBOOKS_DISABLE_DELETE=false

# Only used when running `npm run http` directly instead of Docker Compose.
# MCP_HTTP_PORT=3000
