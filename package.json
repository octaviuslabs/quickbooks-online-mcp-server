{
    "name": "@qboapi/qbo-mcp-server",
    "version": "0.0.1",
    "description": "MCP server implementation for QuickBooks Online integration",
    "license": "MIT",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "qbo-mcp-server": "./dist/index.js",
        "qbo-mcp-http-server": "./dist/http-server.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && shx chmod +x dist/*.js",
        "prepare": "npm run build",
        "watch": "tsc --watch",
        "lint:fix": "eslint --fix",
        "lint": "eslint .",
        "auth": "node dist/auth-server.js",
        "start": "node dist/index.js",
        "start:http": "node dist/http-server.js",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
        "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.20.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^5.1.0",
        "intuit-oauth": "^4.0.0",
        "node-quickbooks": "^2.0.43",
        "open": "^9.1.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@jest/globals": "^30.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.13.10",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.1",
        "globals": "^16.0.0",
        "jest": "^30.2.0",
        "prettier": "3.5.3",
        "shx": "^0.3.4",
        "ts-jest": "^29.4.6",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.1"
    }
}
